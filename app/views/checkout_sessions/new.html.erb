<section class="checkout-page mx-auto max-w-7xl py-12 px-4 sm:px-6 lg:px-8 text-primary">
  <h1 class="text-3xl font-semibold">Checkout</h1>

  <% if @cart.certificate_products.any? %>
    <div class="mt-8 space-y-6">
      <% @cart.certificate_products.includes(:product, :certificate).each do |item| %>
        <div class="rounded-lg bg-background-secondary/50 p-6 shadow-sm">
          <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <div>
              <h2 class="text-xl font-semibold"><%= item.product.title %></h2>
              <p class="mt-2 text-sm text-gray-600"><%= item.certificate.honoree_name.presence || item.certificate.graduate_name %></p>
              <p class="mt-3 text-sm text-gray-700"><%= item.product.description %></p>
            </div>

            <div class="text-right">
              <p class="text-sm text-gray-600">Quantity: <%= item.quantity %></p>
              <p class="mt-2 text-lg font-semibold"><%= number_to_currency(item.total_cents / 100.0, unit: "$", precision: 2) %></p>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-10 rounded-lg bg-background p-6 shadow-sm">
      <div class="flex items-center justify-between">
        <span class="text-lg font-semibold">Order total</span>
        <span class="text-lg font-semibold"><%= number_to_currency(@cart.total_cents / 100.0, unit: "$", precision: 2) %></span>
      </div>

      <%= render "shared/checkout_widget", publishable_key: ENV["STRIPE_KEY_PUB"], button_text: "Start secure checkout" %>
    </div>
  <% else %>
    <div class="mt-8 rounded-lg bg-background-secondary/50 p-6 shadow-sm">
      <p class="text-base text-gray-700">Your cart is empty. Add a certificate and product to start checkout.</p>
    </div>
  <% end %>
</section>
