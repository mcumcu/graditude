<div 
  data-controller="checkout" 
  data-checkout-publishable-key-value="<%= ENV["STRIPE_KEY_PUB"] %>" 
  data-checkout-price-id-value="<%= @price_id %>"
>
  <section class="checkout-page mx-auto max-w-4xl py-12 px-4 sm:px-6 lg:px-8">
    <% if @product.present? %>
      <div class="grid gap-8 lg:grid-cols-[360px_minmax(0,_1fr)]">
        <div class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm">
          <div class="aspect-[4/3] overflow-hidden rounded-2xl bg-gray-100">
            <%= image_tag @product[:image], alt: @product[:name], class: "h-full w-full object-cover" %>
          </div>

          <div class="mt-6">
            <h1 class="text-3xl font-semibold"><%= @product[:name] %></h1>
            <p class="mt-4 text-gray-600"><%= @product[:description] %></p>
            <p class="mt-6 text-2xl font-bold"><%= number_to_currency(@product[:price_cents] / 100.0, unit: "$", precision: 2) %></p>
          </div>

          <ul class="mt-6 space-y-3 text-gray-700">
            <% @product[:features].each do |feature| %>
              <li class="flex items-start gap-3">
                <span class="mt-1 inline-flex h-6 w-6 items-center justify-center rounded-full bg-primary/10 text-primary">✓</span>
                <span><%= feature %></span>
              </li>
            <% end %>
          </ul>
        </div>

        <div class="rounded-3xl border border-gray-200 bg-gray-50 p-6 shadow-sm">
          <div class="mb-6">
            <h2 class="text-xl font-semibold">Order summary</h2>
            <p class="mt-2 text-gray-600">Review your certificate and start secure checkout with Stripe.</p>
          </div>

          <div class="rounded-3xl bg-white p-6 shadow-inner shadow-gray-100">
            <div class="flex items-center justify-between text-gray-600">
              <span>Product</span>
              <span><%= @product[:name] %></span>
            </div>

            <div class="mt-4 flex items-center justify-between text-gray-900">
              <strong>Total</strong>
              <strong><%= number_to_currency(@product[:price_cents] / 100.0, unit: "$", precision: 2) %></strong>
            </div>

            <button type="button" data-action="checkout#startCheckout" data-checkout-target="button" class="mt-8 w-full rounded-xl bg-primary px-5 py-3 text-white hover:bg-primary-dark">
              Start checkout
            </button>
            <p data-checkout-target="feedback" class="mt-4 text-sm text-red-600"></p>
          </div>
        </div>
      </div>
    <% elsif @price_id.present? %>
      <p class="text-center text-gray-700">Unknown product for price ID: <strong><%= @price_id %></strong>.</p>

      <p class="mt-4 text-center text-gray-600">Please return to the previous page and choose a valid product.</p>
    <% else %>
      <p>Please choose a product before starting checkout.</p>
    <% end %>
  </section>
</div>
