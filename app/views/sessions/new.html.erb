<%= render "shared/modal_wrapper", dialog_id: "session-form", title: "Sign in" do %>
  <%= render "sessions/email_form",
    dialog_id: "session-form",
    title: "Sign in",
    submit_text: "Email sign-in link",
    note_html: safe_join([
      "New here? ",
      link_to("Sign up", new_signup_path, command: "show-modal", commandfor: "signup-form", class: "text-content-muted underline hover:no-underline")
    ])
  %>
<% end%>