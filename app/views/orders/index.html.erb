<section class="orders-index mx-auto max-w-7xl px-4 py-16 text-primary sm:px-6 sm:py-24 lg:px-8">
  <div class="mx-auto max-w-4xl">
    <div class="max-w-2xl">
      <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Order history</h1>
      <p class="mt-3 text-base text-content/70 sm:text-lg">Review the progress of recent orders and reopen any order summary.</p>
    </div>

    <% if @orders.any? %>
      <div class="mt-12 space-y-8">
        <% @orders.each do |order| %>
          <article class="rounded-2xl border border-black/10 bg-background-secondary/60 p-6 shadow-sm dark:border-white/10 dark:bg-background">
            <div class="flex flex-col gap-6 border-b border-black/10 pb-6 dark:border-white/10 sm:grid sm:grid-cols-[2fr_1fr_auto] sm:items-start">
              <div class="space-y-2">
                <p class="text-sm uppercase tracking-[0.2em] text-primary/60">Order <%= order.number %></p>
                <h2 class="text-2xl font-semibold"><%= order.status_label %></h2>
                <p class="text-sm text-content/70">Placed <%= order.created_at.strftime("%B %-d, %Y") %></p>
              </div>

              <div class="space-y-2 text-sm text-content/70 sm:text-right">
                <p>Items: <span class="font-semibold text-content"><%= order.checkout_items.sum { |item| item[:quantity].to_i } %></span></p>
                <p>Total: <span class="font-semibold text-content"><%= number_to_currency(order.total_cents.to_i / 100.0) %></span></p>
              </div>

              <div class="flex sm:justify-end">
                <%= link_to "View order", order_path(order), class: "inline-flex items-center justify-center rounded-full bg-primary px-5 py-3 text-sm font-semibold text-white transition hover:opacity-90" %>
              </div>
            </div>

            <div class="mt-6 space-y-4">
              <% order.checkout_items.first(3).each do |item| %>
                <div class="flex items-start justify-between gap-4 rounded-xl bg-background px-4 py-4 dark:bg-background-secondary/40">
                  <div>
                    <p class="font-semibold text-content"><%= item[:product_title].presence || "Graditude certificate" %></p>
                    <% if item[:product_description].present? %>
                      <p class="mt-1 text-sm text-content/70"><%= item[:product_description] %></p>
                    <% end %>
                    <p class="mt-2 text-sm text-content/60">Quantity <%= item[:quantity] %></p>
                  </div>

                  <div class="text-right text-sm font-semibold text-content">
                    <%= number_to_currency((item[:unit_amount].to_i * item[:quantity].to_i) / 100.0) %>
                  </div>
                </div>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="mt-12 rounded-2xl border border-dashed border-black/15 bg-background-secondary/40 p-10 text-center dark:border-white/15 dark:bg-background">
        <h2 class="text-2xl font-semibold">No orders yet</h2>
        <p class="mt-3 text-content/70">Once checkout is completed, your order summaries will appear here.</p>
        <div class="mt-6">
          <%= link_to "Browse certificates", certificates_path, class: "inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white transition hover:opacity-90" %>
        </div>
      </div>
    <% end %>
  </div>
</section>