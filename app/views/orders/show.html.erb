<% status_steps = Order::STATUS_FLOW %>
<% progress_width = (((@order.progress_index * 2) + 1).to_f / (status_steps.length * 2)).clamp(0.0, 1.0) * 100 %>

<section class="order-show bg-background/40 text-primary">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm uppercase tracking-[0.2em] text-primary/60">Order summary</p>
        <h1 class="mt-2 text-3xl font-semibold tracking-tight sm:text-4xl">Order #<%= @order.number %></h1>
        <p class="mt-3 text-base text-content/70">Placed <%= @order.created_at.strftime("%B %-d, %Y") %></p>
      </div>

      <%= link_to "View all orders", orders_path, class: "inline-flex items-center justify-center rounded-full border border-black/10 bg-background px-5 py-3 text-sm font-semibold text-content transition hover:border-primary/30 hover:text-primary dark:border-white/10" %>
    </div>

    <div class="mt-10 grid gap-10 lg:grid-cols-[minmax(0,2fr)_minmax(20rem,1fr)] lg:items-start">
      <div class="space-y-8">
        <section class="rounded-2xl border border-black/10 bg-background-secondary/60 shadow-sm dark:border-white/10 dark:bg-background">
          <div class="border-b border-black/10 px-6 py-6 dark:border-white/10">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <h2 class="text-2xl font-semibold"><%= @order.status_label %></h2>
                <p class="mt-2 text-sm text-content/70">Fulfillment will advance through each step as the order is prepared and delivered.</p>
              </div>

              <div class="rounded-full border border-primary/15 bg-primary/10 px-4 py-2 text-sm font-semibold text-primary">
                <%= @order.status_label %>
              </div>
            </div>

            <% unless @order.canceled? %>
              <div aria-hidden="true" class="mt-6">
                <div class="overflow-hidden rounded-full bg-black/10 dark:bg-white/10">
                  <div class="h-2 rounded-full bg-primary transition-all" style="width: <%= progress_width.round(2) %>%"></div>
                </div>
                <div class="mt-4 hidden grid-cols-4 text-sm font-medium text-content/60 sm:grid">
                  <% status_steps.each_with_index do |step, index| %>
                    <% step_classes = [index.zero? ? "text-left" : "text-center", (index <= @order.progress_index ? "text-primary" : "text-content/60")] %>
                    <% step_classes << "text-right" if index == status_steps.length - 1 %>
                    <div class="<%= step_classes.join(" ") %>"><%= step.humanize %></div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>

          <div class="divide-y divide-black/10 dark:divide-white/10">
            <% @order.checkout_items.each do |item| %>
              <div class="flex flex-col gap-6 px-6 py-6 sm:flex-row sm:items-start sm:justify-between">
                <div class="flex items-start gap-4">
                  <div class="flex h-20 w-20 shrink-0 items-center justify-center rounded-2xl bg-background text-sm font-semibold uppercase tracking-[0.18em] text-primary dark:bg-background-secondary/50">
                    <%= item[:certificate_template].presence || "Order" %>
                  </div>
                  <div>
                    <h3 class="text-lg font-semibold text-content"><%= item[:product_title].presence || "Graditude certificate" %></h3>
                    <% if item[:product_description].present? %>
                      <p class="mt-2 text-sm text-content/70"><%= item[:product_description] %></p>
                    <% end %>
                    <p class="mt-3 text-sm text-content/60">Quantity <%= item[:quantity] %></p>
                  </div>
                </div>

                <div class="text-sm font-semibold text-content sm:text-right">
                  <%= number_to_currency((item[:unit_amount].to_i * item[:quantity].to_i) / 100.0) %>
                </div>
              </div>
            <% end %>
          </div>
        </section>
      </div>

      <div class="space-y-8">
        <section class="rounded-2xl border border-black/10 bg-background-secondary/60 p-6 shadow-sm dark:border-white/10 dark:bg-background">
          <h2 class="text-lg font-semibold">Delivery details</h2>
          <% shipping_options = @order.selected_shipping_options %>
          <% if shipping_options.any? %>
            <div class="mt-4 rounded-xl bg-background px-4 py-4 text-sm dark:bg-background-secondary/40">
              <p class="font-semibold text-content">Selected shipping option<%= "s" if shipping_options.many? %></p>
              <div class="mt-3 space-y-3">
                <% shipping_options.each do |option| %>
                  <% option_currency = option[:currency].to_s.downcase == "usd" ? "$" : "#{option[:currency].to_s.upcase} " %>
                  <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                    <div>
                      <p class="font-medium text-content"><%= option[:display_name] %></p>
                      <% if option[:summary].present? %>
                        <p class="mt-1 text-content/70"><%= option[:summary] %></p>
                      <% end %>
                    </div>
                    <% if option[:amount_cents].present? %>
                      <p class="font-semibold text-content"><%= number_to_currency(option[:amount_cents].to_f / 100.0, unit: option_currency, precision: 2) %></p>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
          <% if @order.shipping_address_lines.any? %>
            <div class="mt-4 space-y-1 text-sm text-content/70">
              <% @order.shipping_address_lines.each do |line| %>
                <p><%= line %></p>
              <% end %>
            </div>
          <% else %>
            <p class="mt-4 text-sm text-content/70">Shipping details will appear here once Stripe provides the completed delivery address.</p>
          <% end %>

          <div class="mt-6 rounded-xl bg-background px-4 py-4 text-sm dark:bg-background-secondary/40">
            <p class="font-semibold text-content">Contact</p>
            <p class="mt-2 text-content/70"><%= @order.user.email_address %></p>
          </div>
        </section>

        <section class="rounded-2xl border border-black/10 bg-background-secondary/60 p-6 shadow-sm dark:border-white/10 dark:bg-background">
          <h2 class="text-lg font-semibold">Order totals</h2>
          <dl class="mt-4 space-y-4 text-sm">
            <div class="flex items-center justify-between text-content/70">
              <dt>Subtotal</dt>
              <dd class="font-semibold text-content"><%= number_to_currency(@order.subtotal_cents / 100.0) %></dd>
            </div>
            <div class="flex items-center justify-between text-content/70">
              <dt>Shipping</dt>
              <dd class="font-semibold text-content"><%= number_to_currency(@order.shipping_total_cents / 100.0) %></dd>
            </div>
            <div class="flex items-center justify-between border-t border-black/10 pt-4 text-content dark:border-white/10">
              <dt class="font-semibold">Order total</dt>
              <dd class="text-base font-semibold text-primary"><%= number_to_currency(@order.total_cents.to_i / 100.0) %></dd>
            </div>
          </dl>

          <div class="mt-6 rounded-xl bg-background px-4 py-4 text-sm dark:bg-background-secondary/40">
            <p class="font-semibold text-content">Stripe session</p>
            <p class="mt-2 break-all text-content/70"><%= @order.checkout_session.stripe_session_id %></p>
          </div>
        </section>
      </div>
    </div>
  </div>
</section>