<% if alert = flash[:alert] %>
  <div class="py-2 px-4 bg-error mb-6 text-background text-lg rounded-full w-full inline-block shadow-sm" id="alert">
    ✖︎ <%= alert %>
  </div>
<% end %>

<% if notice = flash[:notice] %>
  <div class="py-2 px-4 bg-success mb-6 text-background text-lg rounded-full w-full inline-block shadow-sm" id="notice">
    ✹ <%= notice %>
  </div>
<% end %>
