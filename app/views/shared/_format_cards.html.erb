<% products = local_assigns.fetch(:products, []) %>
<% input_name = local_assigns.fetch(:input_name, :preferred_format) %>
<% preferred_format = local_assigns[:preferred_format] %>
<% cart_product_ids = local_assigns.fetch(:cart_product_ids, []) %>
<% cart_items_by_product_id = local_assigns.fetch(:cart_items_by_product_id, {}) %>
<% cart_items_count = local_assigns.fetch(:cart_items_count, 0) %>
<% form_id = local_assigns[:form_id] %>

<div class="mt-3 grid gap-4 grid-cols-1">
  <%= render partial: "shared/format_card",
    collection: products,
    as: :product,
    locals: {
      input_name: input_name,
      preferred_format: preferred_format,
      cart_product_ids: cart_product_ids,
      cart_items_by_product_id: cart_items_by_product_id,
      cart_items_count: cart_items_count,
      form_id: form_id
    } %>
</div>
