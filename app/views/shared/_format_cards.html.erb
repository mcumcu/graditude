<% products = local_assigns.fetch(:products, []) %>
<% input_name = local_assigns.fetch(:input_name, :preferred_format) %>
<% preferred_format = local_assigns[:preferred_format] %>
<% cart_product_ids = local_assigns.fetch(:cart_product_ids, []) %>

<div class="mt-3 grid gap-4 sm:grid-cols-2">
  <% products.each do |product| %>
    <% label = product_variant_label(product) %>
    <% format_value = product_variant_format(product) || label.to_s.downcase %>
    <% option_value = if input_name == :product_id
                        product.id
                      else
                        format_value.presence || "format-#{product.id}"
                      end %>
    <% matches_preference = preferred_format.present? && [option_value.to_s, format_value.to_s, "format-#{product.id}"].include?(preferred_format.to_s) %>
    <% checked = matches_preference %>
    <% in_cart = cart_product_ids.include?(product.id) %>
    <% card_classes = in_cart ? "border-primary/10 opacity-70" : "border-primary/10 hover:border-primary/30" %>

    <% if in_cart %>
      <div data-product-card class="group relative rounded-xl border bg-background-secondary p-4 shadow-sm transition <%= card_classes %>">
        <p class="text-xs uppercase tracking-[0.2em] text-content-muted"><%= label %></p>
        <h3 class="mt-3 text-lg font-semibold text-primary"><%= product.title %></h3>
        <p class="mt-2 text-sm text-content-muted"><%= product.description.presence || "A premium Graditude certificate ready to gift." %></p>
        <div class="mt-4 flex items-center justify-between gap-4">
          <div class="text-lg font-semibold text-primary"><%= formatted_stripe_price(product) || "Pricing unavailable" %></div>
          <%= link_to "Already in cart", cart_path, class: "text-sm font-semibold text-primary hover:text-primary/80" %>
        </div>
      </div>
    <% else %>
      <label data-product-card class="group relative flex cursor-pointer rounded-xl border bg-background-secondary p-4 shadow-sm transition <%= card_classes %>">
        <%= radio_button_tag input_name, option_value, checked, class: "peer sr-only", data: { format_selector_target: "input", action: "format-selector#update" } %>
        <div class="flex-1">
          <span class="block text-base font-semibold text-primary"><%= label %></span>
          <span class="mt-1 block text-sm text-content-muted"><%= product.description.presence || "Museum-grade print and ready-to-gift presentation." %></span>
          <span class="mt-3 block text-base font-semibold text-primary"><%= formatted_stripe_price(product) || "Pricing available" %></span>
        </div>
        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="invisible size-5 text-primary/70 group-hover:text-primary/70 peer-checked:visible">
          <path d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd" fill-rule="evenodd" />
        </svg>
        <span class="pointer-events-none absolute inset-0 rounded-xl ring-2 ring-transparent peer-checked:ring-primary/40"></span>
      </label>
    <% end %>
  <% end %>
</div>
