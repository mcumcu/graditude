<section aria-labelledby="options-heading">
  <h2 id="options-heading" class="sr-only">Certificate options</h2>

  <% form_id = local_assigns.fetch(:form_id, "format-options-form") %>
  <% cart_items_count = local_assigns.fetch(:cart_items_count, 0) %>
  <% multi_select = local_assigns.fetch(:multi_select, false) %>
  <% bind_frame_load = local_assigns.fetch(:bind_frame_load, false) %>
  <% action_value = "turbo:submit-end->format-selector#submitEnd" %>
  <% action_value = "#{action_value} turbo:frame-load->format-selector#update" if bind_frame_load %>

  <%= form_with url: form_url,
                method: form_method,
                class: "space-y-6",
                html: { id: form_id },
                data: {
                  controller: "format-selector",
                  format_selector_requires_selection_value: requires_selection,
                  format_selector_cart_url_value: cart_path,
                  action: action_value
                } do %>
    <% if certificate_id.present? %>
      <%= hidden_field_tag :certificate_id, certificate_id %>
    <% end %>
    <% if quantity.present? %>
      <%= hidden_field_tag :quantity, quantity %>
    <% end %>
    <fieldset>
      <legend class="text-lg font-semibold">Choose a format</legend>
      <% if products.any? %>
        <%= render "shared/format_cards",
          products: products,
          input_name: input_name,
          preferred_format: preferred_format,
          cart_product_ids: cart_product_ids,
          cart_items_by_product_id: cart_items_by_product_id,
          cart_items_count: cart_items_count,
          multi_select: multi_select,
          form_id: form_id %>
      <% else %>
        <div class="mt-3 rounded-xl border border-primary/10 bg-background-secondary p-4 text-sm text-content-muted">
          Product options are being prepared. Please check back soon.
        </div>
      <% end %>
    </fieldset>

    <div class="space-y-3">
      <%= footer_html %>
    </div>
  <% end %>
</section>
