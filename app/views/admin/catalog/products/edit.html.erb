<main class="mx-auto w-full max-w-6xl px-4 py-10">
  <%= render "admin/shared/nav" %>
  <%= render "shared/flash_messages" %>

  <div class="mt-8 flex flex-wrap items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-primary">Edit product</h1>

      <p class="mt-1 text-sm text-content-muted">Update Stripe product data and default price.</p>
    </div>
    <%= link_to "Back to catalog", admin_catalog_products_path, class: "text-sm font-semibold text-primary/70 hover:text-primary" %>
  </div>

  <%= render "form",
    form_url: admin_catalog_product_path(@product),
    form_method: :patch,
    preview_url: preview_admin_catalog_product_path(@product) %>

</main>
