<main class="mx-auto w-full max-w-6xl px-4 py-10">
  <%= render "admin/shared/nav" %>
  <%= render "shared/flash_messages" %>

  <div class="mt-8">
    <h1 class="text-2xl font-bold text-primary">New catalog product</h1>
    <p class="mt-1 text-sm text-content-muted">Create a Stripe product and default price.</p>
  </div>

  <%= render "form",
    form_url: admin_catalog_products_path,
    form_method: :post,
    preview_url: preview_admin_catalog_products_path %>
</main>
