<main class="mx-auto w-full max-w-6xl px-4 py-10">
  <%= render "admin/shared/nav" %>
  <%= render "shared/flash_messages" %>

  <div class="mt-8 flex flex-wrap items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-primary">Catalog</h1>

      <p class="mt-1 text-content-muted">Manage Stripe-backed products and default prices.</p>
    </div>
    <%= link_to "New product", new_admin_catalog_product_path, class: "inline-flex items-center rounded-full bg-primary px-5 py-2 text-sm font-semibold text-white hover:bg-primary/90" %>
  </div>

  <%= turbo_stream_from ::Catalog::Broadcasts::STREAM %>

  <div class="mt-6 overflow-hidden rounded-2xl border border-primary/10 bg-background-secondary">
    <table class="min-w-full divide-y divide-primary/10">
      <thead class="bg-background-secondary/70 text-left text-xs uppercase tracking-wide text-content-muted">
        <tr>
          <th class="px-6 py-3">&nbsp;</th>
          <th class="px-6 py-3">Product</th>
          <th class="px-6 py-3">Templates</th>
          <th class="px-6 py-3">Price</th>
        </tr>
      </thead>
      <tbody id="admin-catalog-products" class="divide-y divide-primary/10">
        <%= render partial: "product_row", collection: @products, as: :product %>
      </tbody>
    </table>
  </div>
</main>
