<main class="mx-auto w-full max-w-6xl px-4 py-10">
  <%= render "admin/shared/nav" %>
  <%= render "shared/flash_messages" %>

  <div class="mt-8">
    <h1 class="text-2xl font-bold text-primary">New shipping rate</h1>
    <p class="mt-1 text-sm text-content-muted">Create a Stripe shipping rate for checkout.</p>
  </div>

  <%= render "form",
    form_url: admin_shipping_rates_path,
    form_method: :post,
    shipping_rate: nil %>
</main>
