<main class="mx-auto w-full max-w-6xl px-4 py-10">
  <%= render "admin/shared/nav" %>
  <%= render "shared/flash_messages" %>

  <div class="mt-8 flex flex-wrap items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-primary">Edit shipping rate</h1>
      <p class="mt-1 text-sm text-content-muted">Update Stripe shipping rate details and status.</p>
    </div>
    <%= link_to "Back to shipping rates", admin_shipping_rates_path, class: "text-sm font-semibold text-primary/70 hover:text-primary" %>
  </div>

  <%= render "form",
    form_url: admin_shipping_rate_path(@shipping_rate),
    form_method: :patch,
    shipping_rate: @shipping_rate %>
</main>
