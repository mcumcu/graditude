<main class="mx-auto w-full max-w-6xl px-4 py-10">
  <%= render "admin/shared/nav" %>
  <%= render "shared/flash_messages" %>

  <div class="mt-8 flex flex-wrap items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-primary">Orders</h1>
      <p class="mt-1 text-content-muted">Track fulfillment progress and respond to Stripe-driven order updates in real time.</p>
    </div>
    <div class="rounded-full border border-primary/10 bg-background-secondary px-4 py-2 text-sm font-semibold text-primary/80">
      <%= pluralize(@orders.count, "order") %>
    </div>
  </div>

  <%= turbo_stream_from ::Orders::Broadcasts::STREAM %>

  <div class="mt-6 overflow-hidden rounded-2xl border border-primary/10 bg-background-secondary">
    <table class="min-w-full divide-y divide-primary/10">
      <thead class="bg-background-secondary/70 text-left text-xs uppercase tracking-wide text-content-muted">
        <tr>
          <th class="px-6 py-3">Status</th>
          <th class="px-6 py-3">Order</th>
          <th class="px-6 py-3">Delivery</th>
          <th class="px-6 py-3">Total</th>
        </tr>
      </thead>
      <tbody id="admin-orders" class="divide-y divide-primary/10">
        <%= render partial: "order_row", collection: @orders, as: :order %>
      </tbody>
    </table>
  </div>
</main>