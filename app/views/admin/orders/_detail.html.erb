<% status_classes = {
  "order_placed" => "border-primary/25 text-primary bg-primary/5",
  "processing" => "border-warning/25 text-warning bg-warning/10",
  "shipping" => "border-primary/25 text-primary bg-primary/5",
  "received" => "border-success/25 text-success bg-success/10",
  "canceled" => "border-error/25 text-error bg-error/10"
} %>
<% transition_labels = {
  "processing" => "Mark processing",
  "shipping" => "Mark shipped",
  "received" => "Mark received",
  "canceled" => "Cancel order"
} %>
<% currency = order.currency.to_s.downcase == "usd" ? "$" : "#{order.currency.to_s.upcase} " %>
<% return_transition_status = order.return_transition_status %>
<% forward_transition_statuses = order.allowed_transition_statuses - [ return_transition_status ].compact %>

<div id="<%= Orders::Broadcasts.detail_dom_id(order) %>" class="mt-6 space-y-6">
  <section class="rounded-2xl border border-primary/10 bg-background-secondary p-6 shadow-sm">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <div class="inline-flex rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-wide <%= status_classes.fetch(order.status, status_classes["order_placed"]) %>">
          <%= order.status_label %>
        </div>
        <h2 class="mt-4 text-xl font-semibold text-primary">Fulfillment controls</h2>
        <p class="mt-2 text-sm text-content-muted">Only transitions allowed by the current order state are shown.</p>
      </div>

      <div class="rounded-2xl border border-primary/10 bg-background px-4 py-4 text-sm text-content-muted">
        <div>Customer: <span class="font-semibold text-primary"><%= order.user.email_address %></span></div>
        <div class="mt-2">Placed: <span class="font-semibold text-primary"><%= order.created_at.strftime("%B %-d, %Y at %-I:%M %p") %></span></div>
        <div class="mt-2">Checkout status: <span class="font-semibold text-primary"><%= order.checkout_session.status.humanize %></span></div>
      </div>
    </div>

    <div class="mt-6 flex flex-wrap gap-3">
      <% if return_transition_status.present? %>
        <%= button_to transition_admin_order_path(order, status: return_transition_status, return_to: "show"), method: :patch, class: "inline-flex", form_class: "inline-flex" do %>
          <span class="inline-flex items-center gap-2 rounded-full border border-primary/20 bg-background px-4 py-2 text-sm font-semibold text-primary transition hover:border-primary/35 hover:bg-primary/5">
            <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-4">
              <path d="M9.03 4.97a.75.75 0 0 1 0 1.06L5.81 9.25H15a.75.75 0 0 1 0 1.5H5.81l3.22 3.22a.75.75 0 1 1-1.06 1.06l-4.5-4.5a.75.75 0 0 1 0-1.06l4.5-4.5a.75.75 0 0 1 1.06 0Z" />
            </svg>
            <%= "Return to #{return_transition_status.humanize.downcase}" %>
          </span>
        <% end %>
      <% end %>

      <% if forward_transition_statuses.any? %>
        <% forward_transition_statuses.each do |target_status| %>
          <%= button_to transition_admin_order_path(order, status: target_status, return_to: "show"), method: :patch, class: "inline-flex", form_class: "inline-flex" do %>
            <span class="inline-flex items-center rounded-full border border-primary/15 bg-white px-4 py-2 text-sm font-semibold text-primary transition hover:border-primary/30 hover:bg-primary/5 dark:bg-background">
              <%= transition_labels.fetch(target_status, target_status.humanize) %>
            </span>
          <% end %>
        <% end %>
      <% elsif return_transition_status.blank? %>
        <span class="text-sm text-content-muted">No further fulfillment actions are permitted.</span>
      <% end %>
    </div>
  </section>

  <div class="grid gap-6 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
    <section class="rounded-2xl border border-primary/10 bg-background-secondary p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-primary">Order contents</h2>
      <div class="mt-5 space-y-4">
        <% order.checkout_items.each do |item| %>
          <div class="rounded-2xl border border-primary/10 bg-background p-4">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <div class="text-base font-semibold text-primary"><%= item[:product_title].presence || "Graditude certificate" %></div>
                <% if item[:product_description].present? %>
                  <div class="mt-2 text-sm text-content-muted"><%= item[:product_description] %></div>
                <% end %>
                <div class="mt-2 text-xs uppercase tracking-wide text-content-muted">Template <%= item[:certificate_template].presence || "n/a" %></div>
              </div>
              <div class="text-sm text-content-muted sm:text-right">
                <div>Qty <span class="font-semibold text-primary"><%= item[:quantity] %></span></div>
                <div class="mt-1 font-semibold text-primary"><%= number_to_currency((item[:unit_amount].to_i * item[:quantity].to_i) / 100.0, unit: currency, precision: 2) %></div>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        <div class="rounded-2xl border border-primary/10 bg-background p-4">
          <div class="text-xs uppercase tracking-wide text-content-muted">Stripe session</div>
          <div class="mt-2 break-all text-sm font-semibold text-primary"><%= order.checkout_session.stripe_session_id %></div>
        </div>
        <div class="rounded-2xl border border-primary/10 bg-background p-4">
          <div class="text-xs uppercase tracking-wide text-content-muted">Order total</div>
          <div class="mt-2 text-sm font-semibold text-primary"><%= number_to_currency(order.total_cents.to_f / 100.0, unit: currency, precision: 2) %></div>
        </div>
      </div>
    </section>

    <section class="rounded-2xl border border-primary/10 bg-background-secondary p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-primary">Delivery details</h2>
      <% shipping_options = order.selected_shipping_options %>
      <% if shipping_options.any? %>
        <div class="mt-5 rounded-2xl border border-primary/10 bg-background p-4 text-sm text-content-muted">
          <div class="text-xs uppercase tracking-wide">Selected shipping option<%= "s" if shipping_options.many? %></div>
          <div class="mt-3 space-y-3">
            <% shipping_options.each do |option| %>
              <% option_currency = option[:currency].to_s.downcase == "usd" ? "$" : "#{option[:currency].to_s.upcase} " %>
              <div class="rounded-xl border border-primary/10 bg-background-secondary/60 p-3">
                <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                  <div>
                    <div class="font-semibold text-primary"><%= option[:display_name] %></div>
                    <% if option[:summary].present? %>
                      <div class="mt-1 text-xs text-content-muted"><%= option[:summary] %></div>
                    <% end %>
                  </div>
                  <% if option[:amount_cents].present? %>
                    <div class="text-sm font-semibold text-primary"><%= number_to_currency(option[:amount_cents].to_f / 100.0, unit: option_currency, precision: 2) %></div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
      <% if order.shipping_address_lines.any? %>
        <div class="mt-5 rounded-2xl border border-primary/10 bg-background p-4 text-sm text-content-muted">
          <% order.shipping_address_lines.each do |line| %>
            <div><%= line %></div>
          <% end %>
        </div>
      <% else %>
        <div class="mt-5 rounded-2xl border border-dashed border-primary/15 bg-background p-4 text-sm text-content-muted">
          Shipping details are still pending from Stripe.
        </div>
      <% end %>

      <div class="mt-6 rounded-2xl border border-primary/10 bg-background p-4 text-sm text-content-muted">
        <div class="text-xs uppercase tracking-wide">Checkout session snapshot</div>
        <pre class="mt-3 overflow-x-auto whitespace-pre-wrap break-words rounded-xl bg-background-secondary/70 p-4 text-xs text-primary"><%= JSON.pretty_generate(order.checkout_session.as_json(only: [ :id, :status, :stripe_session_id, :shipping_total_cents, :shipping_currency ])) %></pre>
      </div>
    </section>
  </div>

  <div class="grid gap-6 lg:grid-cols-2">
    <section class="rounded-2xl border border-primary/10 bg-background-secondary p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-primary">Order raw payload</h2>
      <details class="group mt-5">
        <summary class="flex cursor-pointer list-none items-center gap-2 text-sm font-semibold text-primary marker:hidden">
          <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-4 transition-transform group-open:rotate-90">
            <path d="M7 5.5 13 10l-6 4.5v-9Z" />
          </svg>
          <span>Expand payload</span>
        </summary>
        <div class="mt-4 max-h-80 overflow-auto rounded-2xl bg-background p-4 group-open:max-h-none">
          <pre class="overflow-x-auto whitespace-pre-wrap break-words text-xs text-primary"><%= JSON.pretty_generate(order.raw_hash) %></pre>
        </div>
      </details>
    </section>

    <section class="rounded-2xl border border-primary/10 bg-background-secondary p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-primary">Checkout session raw payload</h2>
      <details class="group mt-5">
        <summary class="flex cursor-pointer list-none items-center gap-2 text-sm font-semibold text-primary marker:hidden">
          <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-4 transition-transform group-open:rotate-90">
            <path d="M7 5.5 13 10l-6 4.5v-9Z" />
          </svg>
          <span>Expand payload</span>
        </summary>
        <div class="mt-4 max-h-80 overflow-auto rounded-2xl bg-background p-4 group-open:max-h-none">
          <pre class="overflow-x-auto whitespace-pre-wrap break-words text-xs text-primary"><%= JSON.pretty_generate(order.checkout_session.raw_hash) %></pre>
        </div>
      </details>
    </section>
  </div>
</div>