<% content_for :title, "Certificates #{pluralize(@certificates.count, "Certificate")}" %>

<div class="container mx-auto flex flex-col gap-8 pt-6">
  <div class="flex flex-col justify-center items-center gap-8">
    <h1 class="font-headline text-3xl">My <%= pluralize(@certificates.count, "Certificate") %></h1>
  </div>

  <% if notice.present? %>
    <%= render partial: "notice", locals: {certificate: @certificate} %>
  <% end %>

  <div id="certificates" class="min-w-full flex flex-col gap-16">
    <% if @certificates.any? %>
      <% @certificates.each do |certificate| %>
        <%= link_to certificate_path(certificate), class: "flex flex-col gap-8" do %>
          <%= render certificate %>

          <%#= render partial: "action_buttons", locals: {certificate: certificate, show_edit: false} %>
        <% end %>
      <% end %>
    <% else %>
      <p class="text-center my-10">No certificates found.</p>
    <% end %>
  </div>
</div>
