<% content_for :title do %>
  Edit Certificate
<% end %>

<div class="mt-8 mx-auto md:w-2/3 w-full flex flex-col gap-8">
  <h1 class="font-bold text-4xl">
    Certificate for <%= @certificate.honoree_name %>
  </h1>

  <%= render "shared/modal_wrapper", dialog_id: "certificate-form", title: "Edit Certificate", close_path: certificates_path do %>
    <%= render "form", certificate: @certificate, close_path: certificates_path %>
  <% end %>
</div>
