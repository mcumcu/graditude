<% content_for :title do %>
  Certificate Preview
<% end %>

<div class="mx-auto flex flex-col gap-8 pt-6">
  <div class="flex flex-col justify-center items-center gap-8">
    <h1 class="font-headline text-3xl">Certificate for <%= @certificate.honoree_name %></h1>
    <% @products.each do |product| %>
      <div class="flex flex-row justify-between items-center gap-8 w-full">
        <div class="text-base font-medium text-gray-700 dark:text-gray-300">
          <%= product.title %> <%= formatted_stripe_price(product) %>
        </div>

        <div>
          <%= render "shared/add_to_cart_button", certificate: @certificate, product_id: product.id %>
        </div>
      </div>
    <% end %>
  </div>

  <%= render "shared/flash_messages" %>

  <%= render @certificate %>

  <%= render partial: "action_buttons", locals: {certificate: @certificate, show_edit: true} %>

</div>
