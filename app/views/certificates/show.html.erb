<% content_for :title do %>
  Certificate Preview
<% end %>

<% preferred_format = @preferred_format %>
<% total_cart_items_count = cart_items_count %>

<% image_html = capture do %>
  <%= render "preview_image", certificate: @certificate, class: "aspect-4/3 w-full rounded-xl" %>
<% end %>

<% options_html = format_options_form(
  form_url: cart_items_path,
  form_method: :post,
  requires_selection: true,
  products: @products,
  input_name: :product_id,
  preferred_format: preferred_format,
  cart_product_ids: @cart_product_ids,
  cart_items_by_product_id: @cart_items_by_product_id,
  cart_items_count: total_cart_items_count,
  certificate_id: @certificate.id,
  quantity: 1
) do %>
  <%= submit_tag "Add to cart",
    class: "flex w-full items-center justify-center rounded-full bg-primary px-8 py-3 text-base font-semibold text-background shadow-sm transition hover:bg-primary/80 disabled:opacity-50 disabled:cursor-not-allowed mt-6",
    data: { format_selector_target: "submit", action: "click->format-selector#submitOrNavigate" },
    disabled: preferred_format.blank? %>
  <p
    class="text-sm text-content-muted mt-6"
    data-format-selector-target="helperText"
    data-helper-zero="Select one or more formats to add to the cart."
    data-helper-one="Add the selected format to the cart."
    data-helper-many="Add the selected formats to the cart."
    data-helper-all="You've successfully cartmaxxed. Time to check out!"
  >
    Select one or more formats to add to the cart.
  </p>
<% end %>

<%= render "shared/product_page",
  template: @certificate.template,
  products: @products,
  certificate: @certificate,
  show_edit: true,
  image_html: image_html,
  options_html: options_html,
  show_details: false
%>
