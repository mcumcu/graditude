<div data-controller="visibility">
  <%= render "form_modal", certificate: certificate %>

  <div class="flex flex-col md:flex-row justify-center gap-8 p-8 md:p-0" data-visibility-target="hideable">
    <% if (product_id = add_to_cart_product_id_for_template(certificate.template)) %>
      <%= form_with(url: cart_items_path, method: :post, local: true) do |f| %>
        <%= f.hidden_field :product_id, value: product_id %>
        <%= f.hidden_field :certificate_id, value: certificate.id %>
        <%= f.hidden_field :quantity, value: 1 %>

        <%= f.submit "Add to cart", class: "w-full min-w-48 text-background dark:text-background lg:w-auto text-center rounded-full px-3 py-2 bg-primary/80 hover:bg-primary dark:bg-primary-dark/80 dark:hover:bg-primary-dark inline-block font-medium" %>
      <% end %>
    <% end %>

    <% if show_edit %>
      <button command="show-modal" commandfor="certificate-form" class="w-full min-w-48 text-background dark:text-background lg:w-auto text-center rounded-full px-3 py-2 bg-primary/80 hover:bg-primary dark:bg-primary-dark/80 dark:hover:bg-primary-dark inline-block font-medium">Edit</button>
    <% end %>

    <%= button_to "✖︎ Delete", certificate, method: :delete, class: "w-full min-w-48 text-background dark:text-background lg:w-auto text-center rounded-full px-3 py-2 bg-primary/80 hover:bg-primary dark:bg-primary-dark/80 dark:hover:bg-primary-dark inline-block font-medium", data: { turbo_confirm: "Are you sure?" } %>
  </div>
</div>
