<div data-controller="visibility">
  <%= render "form_modal", certificate: certificate, close_path: certificate_path(certificate) %>

  <% in_cart = certificate_in_cart?(certificate) %>
  <div class="flex flex-col gap-4 py-4 md:flex-row md:items-center md:gap-4 md:py-0" data-visibility-target="hideable">
    <% if show_edit %>
      <div class="w-full md:flex-1">
        <button command="show-modal" commandfor="certificate-form" class="w-full text-background dark:text-background text-center rounded-full px-3 py-2 bg-primary/80 hover:bg-primary dark:bg-primary-dark/80 dark:hover:bg-primary-dark inline-block font-medium hover:cursor-pointer">Edit</button>
      </div>
    <% end %>

    <div class="w-full md:flex-1">
      <%= link_to "New", product_path, class: "w-full text-background dark:text-background text-center rounded-full px-3 py-2 bg-secondary/80 hover:bg-secondary inline-block font-medium" %>
    </div>

    <%= button_to "✖︎ Delete", certificate,
      method: :delete,
      disabled: in_cart,
      class: [
        "w-full text-background dark:text-background text-center rounded-full px-3 py-2 bg-primary/80",
        "inline-block font-medium",
        in_cart ? "opacity-50 cursor-not-allowed" : "hover:bg-primary dark:bg-primary-dark/80 dark:hover:bg-primary-dark hover:cursor-pointer"
      ].join(" "),
      form: { class: "w-full md:flex-1" },
      data: (in_cart ? {} : { turbo_confirm: "Are you sure?" }),
      title: (in_cart ? "Remove this certificate from the cart to delete it." : nil),
      aria: { disabled: in_cart } %>
  </div>
</div>
