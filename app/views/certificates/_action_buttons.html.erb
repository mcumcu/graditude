<div data-controller="visibility">
  <%= render "form_modal", certificate: certificate, close_path: certificate_path(certificate) %>

  <% in_cart = certificate_in_cart?(certificate) %>
  <% purchased = certificate_purchased?(certificate) %>
  <% delete_disabled = in_cart || purchased %>
  <% button_class = "w-full text-center rounded-full px-3 py-2 inline-block font-medium text-content/50 border border-content/30 cursor-pointer" %>

  <div class="flex flex-col gap-4 py-4 md:flex-row md:items-center md:gap-4 md:py-0" data-visibility-target="hideable">
    <% if show_edit %>
      <div class="w-full md:flex-1">
        <button command="show-modal" commandfor="certificate-form" class="<%= button_class %>">
          Edit
        </button>
      </div>
    <% end %>

    <div class="w-full md:flex-1">
      <%= link_to "New",
        new_certificate_path(close_path: request.fullpath),
        class: button_class  %>
    </div>

    <%= button_to "Delete", certificate,
      method: :delete,
      disabled: delete_disabled,
      class: [
        button_class,
        delete_disabled ? "opacity-50 cursor-not-allowed" : nil
      ].compact.join(" "),
      form: { class: "w-full md:flex-1" },
      data: (delete_disabled ? {} : { turbo_confirm: "Are you sure?" }),
      title: (in_cart ? "Remove this certificate from the cart before deleting it." : (purchased ? "Purchased certificates cannot be deleted." : nil)),
      aria: { disabled: delete_disabled } %>
  </div>
</div>
