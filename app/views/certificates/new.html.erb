<% content_for :title do %>
  Create a Certificate
<% end %>

<% close_path = safe_close_path(params[:close_path].presence || request.referer, fallback: certificates_path) %>

<%= render "shared/modal_wrapper", dialog_id: "certificate-form", title: "Create a Certificate", close_path: close_path do |close_action| %>
  <%= render "form", certificate: @certificate, close_path: close_path %>
<% end %>
