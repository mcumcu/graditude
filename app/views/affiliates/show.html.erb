<% content_for :title do %>
  Affiliate Dashboard
<% end %>

<div class="mx-auto w-full max-w-2xl px-6 py-16">
  <h1 class="text-3xl font-bold mb-6">Affiliate Dashboard</h1>

  <%= render "shared/flash_messages" %>

  <div class="rounded-lg border border-black/10 dark:border-white/10 p-6 bg-background-secondary dark:bg-background">
    <p class="text-content-muted">Your referral link</p>

    <div class="mt-3 flex flex-col gap-3">
      <input
        type="text"
        readonly
        value="<%= @referral_url %>"
        class="w-full px-3 py-2 rounded-md border border-black/30 dark:border-white/30 bg-background text-content"
      />

      <p class="text-sm text-content-muted">Share this link to attribute new signups to you.</p>
    </div>
  </div>
</div>
