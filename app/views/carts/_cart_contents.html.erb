<% cart_items = cart.certificate_products.includes(:product, :certificate) %>
<% single_item = cart_items.size == 1 %>
<% shipping_formats = cart_items.map { |item| item.product.variant_format.to_s.downcase }.reject(&:blank?).uniq %>
<% shipping_rates_by_format = shipping_formats.each_with_object({}) do |format, acc|
     acc[format] = ShippingRate.active.for_format(format).order(default_rate: :desc, updated_at: :desc).to_a
   end %>
<% shipping_counts = cart_items.each_with_object(Hash.new(0)) do |item, acc|
     format = item.product.variant_format.to_s.downcase
     next if format.blank?

     acc[format] += item.quantity
   end %>
<% items_total_cents = cart.total_cents.to_i %>
<% shipping_total_cents = 0 %>
<% shipping_currency = shipping_rates_by_format.values.flatten.map(&:stripe_currency).compact.first || "usd" %>
<% shipping_rates_by_format.each do |format, rates|
     next if rates.empty?

     rate = rates.find(&:default_rate?) || rates.first
     count = shipping_counts[format].to_i
     quantity = rate.billing_basis == "per_item" ? count : 1
     amount_cents = rate.stripe_amount_cents
     shipping_total_cents += amount_cents.to_i * quantity if amount_cents.present?
   end %>
<% currency_unit = shipping_currency.to_s.downcase == "usd" ? "$" : "#{shipping_currency.to_s.upcase} " %>

<% if cart_items.any? %>
  <ul role="list" class="divide-y divide-gray-400/50 border-t border-b border-gray-400/50">
    <% cart_items.each do |item| %>
      <li class="py-6" id="cart-item-row-#{item.id}">
        <%= turbo_frame_tag "cart-item-#{item.id}", class: "flex" do %>
          <div class="border border-gray-200/50 rounded-lg shadow-sm shrink-0 bg-white">
            <%= image_tag "#{item.certificate.template}.png", alt: "#{item.product.stripe_name} thumbnail", class: "h-24 w-24 rounded-md object-contain sm:h-32 sm:w-32" %>
          </div>

          <div class="ml-4 flex flex-1 flex-col sm:ml-6">
            <div>
              <div class="flex justify-between">
                <h3 class="text-lg">
                  <span class="font-medium"><%= item.product.stripe_name %></span>
                </h3>

                <p class="ml-4 text-sm"><%= number_to_currency(item.total_cents / 100.0, unit: "$", precision: 2) %></p>
              </div>

              <p class="mt-1 text-sm">For <%= item.certificate.honoree_name %>. <%= item.product.stripe_description %> </p>
            </div>

            <div class="mt-4 flex flex-1 items-end justify-between">
              <p class="flex items-center space-x-2 text-sm text-success">
                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="h-5 w-5 shrink-0">
                  <path d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" fill-rule="evenodd" />
                </svg>

                <span>In stock</span>
              </p>

              <div class="ml-4">
                <%= render "shared/minus_icon_button",
                  path: cart_item_path(item, source: "cart"),
                  turbo_frame: (single_item ? "_top" : "cart-item-#{item.id}"),
                  turbo_stream: !single_item %>
              </div>
            </div>
          </div>
        <% end %>
      </li>
    <% end %>
  </ul>

  <section aria-labelledby="summary-heading" class="mt-10">
    <h2 id="summary-heading" class="sr-only">Order summary</h2>

    <div data-checkout-summary-target="summary"
         data-controller="shipping-summary"
         data-shipping-summary-items-total-cents-value="<%= items_total_cents %>"
         data-shipping-summary-currency-value="<%= shipping_currency.to_s.upcase %>">
      <% if shipping_rates_by_format.any? %>
        <div class="space-y-4">
          <div>
            <h3 class="text-base font-semibold text-primary">Shipping options</h3>
            <p class="text-sm text-content-muted">Select a shipping option for each format before checkout.</p>
          </div>

          <% shipping_rates_by_format.each do |format, rates| %>
            <% next if rates.empty? %>
            <% rates = rates.sort_by do |rate|
                 amount_cents = rate.stripe_amount_cents
                 [rate.default_rate? ? 0 : 1, amount_cents.nil? ? 9_999_999_999 : amount_cents]
               end %>
            <% format_label = format == "framed" ? "Framed shipping" : "Print shipping" %>
            <% default_rate = rates.find(&:default_rate?) || rates.first %>

            <div class="space-y-3" data-shipping-format="<%= format %>">
              <p class="text-sm font-semibold text-content"><%= format_label %></p>
              <div class="grid gap-4 grid-cols-1">
                <% rates.each do |rate| %>
                  <% amount_cents = rate.stripe_amount_cents %>
                  <% currency = rate.stripe_currency || "usd" %>
                  <% unit = currency.to_s.downcase == "usd" ? "$" : "#{currency.to_s.upcase} " %>
                  <% delivery_label = rate.delivery_window_label || "Delivery window varies" %>
                  <% billing_label = rate.billing_basis.to_s.tr("_", " ").titleize %>
                  <% checked = rate == default_rate %>
                  <% count = shipping_counts[format].to_i %>
                  <% quantity = rate.billing_basis == "per_item" ? count : 1 %>
                  <% option_total_cents = amount_cents.present? ? amount_cents.to_i * quantity : 0 %>
                  <% amount_label = amount_cents ? number_to_currency(amount_cents.to_f / 100.0, unit: unit, precision: 2) : "Pricing unavailable" %>

                  <label class="group relative flex w-full cursor-pointer rounded-xl border border-primary/10 bg-background-secondary p-4 shadow-sm transition hover:border-primary/30">
                    <%= radio_button_tag "shipping_rate_ids[#{format}]", rate.id, checked,
                      class: "peer sr-only",
                      data: {
                        action: "change->shipping-summary#update",
                        shipping_total_cents: option_total_cents
                      } %>

                    <%# gray plus sign %>
                    <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="absolute right-3 top-3 size-6 text-primary/30 peer-checked:invisible">
                      <path d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm.75-11.25a.75.75 0 0 0-1.5 0v2.5h-2.5a.75.75 0 0 0 0 1.5h2.5v2.5a.75.75 0 0 0 1.5 0v-2.5h2.5a.75.75 0 0 0 0-1.5h-2.5v-2.5Z" clip-rule="evenodd" fill-rule="evenodd" />
                    </svg>

                    <%# green check mark %>
                    <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="absolute right-3 top-3 invisible size-6 text-primary/50 peer-checked:visible">
                      <path d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd" fill-rule="evenodd" />
                    </svg>

                    <div class="relative flex flex-1 flex-col">
                      <div class="flex items-start justify-between gap-4">
                        <div>
                          <span class="block text-base font-semibold text-primary"><%= rate.stripe_display_name || "Shipping" %></span>
                          <span class="mt-1 block text-sm text-content-muted"><%= delivery_label %></span>
                          <span class="mt-1 block text-xs text-content-muted"><%= billing_label %></span>
                        </div>
                      </div>
                      <span class="absolute bottom-0 right-0 text-right text-base font-semibold text-primary"><%= amount_label %></span>
                      <%# Default rate remains pre-selected but no badge is shown. %>
                    </div>

                    <span class="pointer-events-none absolute inset-0 rounded-xl ring-2 ring-transparent peer-checked:ring-primary/40"></span>
                  </label>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="mt-1 text-sm text-content-muted">Shipping options are not available yet. Please check back soon.</p>
      <% end %>

      <dl class="mt-8 space-y-4">
        <div class="flex items-center justify-between text-sm text-content-muted">
          <dt>Items</dt>
          <dd class="ml-4"><%= number_to_currency(items_total_cents / 100.0, unit: currency_unit, precision: 2) %></dd>
        </div>
        <div class="flex items-center justify-between text-sm text-content-muted">
          <dt>Shipping</dt>
          <dd class="ml-4" data-shipping-summary-target="shippingAmount"><%= number_to_currency(shipping_total_cents / 100.0, unit: currency_unit, precision: 2) %></dd>
        </div>
        <div class="flex items-center justify-between border-t border-primary/10 pt-4">
          <dt class="text-lg font-medium">Subtotal</dt>
          <dd class="ml-4 text-lg font-medium" data-shipping-summary-target="subtotalAmount"><%= number_to_currency((items_total_cents + shipping_total_cents) / 100.0, unit: currency_unit, precision: 2) %></dd>
        </div>
      </dl>

      <p class="mt-2 text-sm text-content-muted">Taxes are calculated at checkout.</p>
    </div>

    <%= render "shared/checkout_widget", publishable_key: ENV["STRIPE_KEY_PUB"], button_text: "Checkout" %>

    <div data-checkout-summary-target="summary" class="mt-12 text-center text-sm">
      <p>
        or
        <%= link_to "Continue shopping", product_path, class: "font-medium" %>
      </p>
    </div>
  </section>
<% else %>
  <p class="text-center">Your cart is empty. Add a certificate and a product to continue.</p>
<% end %>
