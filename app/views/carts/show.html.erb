<section class="cart-page">
  <div class="mx-auto max-w-5xl px-4 py-16 sm:px-6 sm:py-24 lg:px-0 text-content">
    <div class="mt-12 bg-background-secondary p-8 rounded-lg shadow-sm space-y-4">
      <h1 class="text-center text-3xl sm:text-4xl py-8">Shopping Cart</h1>

      <section aria-labelledby="cart-heading">
        <h2 id="cart-heading" class="sr-only">Items in your shopping cart</h2>
        <div id="cart-contents">
          <%= render "cart_contents", cart: @cart %>
        </div>
      </section>
    </div>
  </div>
</section>
