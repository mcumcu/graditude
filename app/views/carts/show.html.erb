<section class="cart-page mx-auto max-w-7xl py-12 px-4 sm:px-6 lg:px-8 text-primary">
  <h1 class="text-3xl font-semibold">Your cart</h1>

  <% if @cart.certificate_products.any? %>
    <div class="mt-8 space-y-6">
      <% @cart.certificate_products.includes(:product, :certificate).each do |item| %>
        <div class="rounded-lg bg-background-secondary/50 p-6 shadow-sm">
          <h2 class="text-xl font-semibold"><%= item.product.title %></h2>
          <p class="mt-2 text-sm text-gray-600"><%= item.certificate.honoree_name.presence || item.certificate.graduate_name %></p>
          <p class="mt-4 text-sm"><%= item.product.description %></p>
          <div class="mt-4 flex items-center justify-between">
            <span class="text-sm text-gray-700">Quantity: <%= item.quantity %></span>
            <span class="text-base font-semibold"><%= number_to_currency(item.total_cents / 100.0, unit: "$", precision: 2) %></span>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-10 rounded-lg bg-background p-6 shadow-sm">
      <div class="flex items-center justify-between">
        <span class="text-lg font-semibold">Total</span>
        <span class="text-lg font-semibold"><%= number_to_currency(@cart.total_cents / 100.0, unit: "$", precision: 2) %></span>
      </div>

      <div class="mt-6">
        <a href="<%= new_checkout_path %>" class="inline-flex items-center justify-center rounded-full bg-black text-white px-8 py-4 text-lg font-bold">Checkout</a>
      </div>
    </div>
  <% else %>
    <div class="mt-8 rounded-lg bg-background-secondary/50 p-6 shadow-sm">
      <p>Your cart is empty. Add a certificate and a product to continue.</p>
    </div>
  <% end %>
</section>
